                <ion-icon class="dash" id="dash2"  name="close-outline"></ion-icon>
                <img id="img_logo" src="{{ asset('images/logo.png') }}" alt="" />
                <h2>Sana<span style="color:rgb(23, 7, 255);">Connect</span></h2>
            </div>
            <header id="header">
                <nav id="nav-bar">
                    <ul id="ul_nav">
                        <li id="li_nav"><a class="nav-link" href="#Home">Home</a></li>
                        <li id="li_nav"><a class="nav-link" href="#Modules">Modules</a></li>
                        <li id="li_nav"><a class="nav-link" href="#Evaluation">Produits</a></li>
                        <li id="li_nav"><a class="nav-link" href="{{ path('app_anonce_index') }}">Evenement</a></li>
