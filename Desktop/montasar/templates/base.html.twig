                <ion-icon id="message" name="chatbox-ellipses-outline"></ion-icon>
                
                <!-- Profile Image -->
                <img src="{{ asset('images/profile.png') }}" id="img_profile" alt="">

                <!-- Profile Dropdown -->
                {% if app.session.get('user') %}
                <div id="profile-dropdown" class="dropdown-content">
                    <p>{{ app.session.get('user').nom }} {{ app.session.get('user').prenom }}</p>
                    <a href="{{ path('app_logout') }}" >Logout</a>
                </div>
                {% endif %}
            </div>

        </div>
        <div id="body">
            <div id="menu">
                    <div id="GestionEvaluation">
                        <div id="togother">
                        <ion-icon id="logo_m" name="clipboard-outline"></ion-icon>
                        <a id="a_module" href="{{ path('app_account_index') }}">Gestion Des Accounts</a>
                        </div>
                        <ul id="ul_eva">
                           
                            <li class="li_eva">
                                <a  href="{{ path('app_account_index') }}"  >Users Page</a>
                             </li>
                        </ul>
                    </div>
                    <br/>
            </div>
            <div id="content">
            {% block content %}
            
            {% endblock  %}
            </div>
        </div>
        <div id="footer"></div>
