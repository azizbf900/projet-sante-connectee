                        <li id="li_nav"><a class="nav-link" href="{{ path('app_evenement_index') }}">Annonces</a></li>
                
                        <li id="li_nav"><a class="nav-link" href="#Cours">Rendez Vous</a></li>
                        
                    </ul>
                </nav>
            </header>
            <div id="profile" class="profile-container">
