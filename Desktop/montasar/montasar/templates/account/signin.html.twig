<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script
      src="https://kit.fontawesome.com/64d58efce2.js"
      crossorigin="anonymous"
    ></script>
    <link rel="stylesheet" href="{{asset('assetsFront/css/signin.css')}}" />
    <title>Sign in & Sign up Form</title>
  </head>
  <body>

    <div class="container">
      <div class="forms-container">
        <div class="signin-signup">


{% for message in app.flashes('danger') %}
    <script type="text/javascript">
        alert("{{ message }}");
    </script>
{% endfor %}
          <form action="{{path('app_login')}}" class="sign-in-form" method="post">
            <h2 class="title">Sign in</h2>
            <div class="input-field">
              <i class="fas fa-user"></i>
              <input type="text" placeholder="mail" name="mail" id="mail" />
            </div>

            <div class="input-field">
              <i class="fas fa-lock"></i>
              <input type="password" placeholder="Password" name="password"/>
            </div>

            <input type="submit" value="Login" class="btn solid" />
            <a href="#" onclick="resetPassword()"class="btn solid" style="text-align: center; display: block; width: 150px; outline:0;line-height: 40px; height:40px;text-decoration: none;text-transform: none;">Reset Password</a>
            <p class="social-text">Or Sign in with social platforms</p>

            <div class="social-media">
              <a href="#" class="social-icon">
                <i class="fab fa-facebook-f"></i>
              </a>
              <a href="#" class="social-icon">
                <i class="fab fa-twitter"></i>
              </a>
              <a href="#" class="social-icon">
                <i class="fab fa-google"></i>
              </a>
              <a href="#" class="social-icon">
                <i class="fab fa-linkedin-in"></i>
              </a>
            </div>
          </form>



  <!-- 
    - #signup
  -->

          
        {{ form_start(form, {'attr': {'class': 'sign-up-form'}}) }}
            <h2 class="title">Sign up</h2>

            <!-- Nom Field -->
            <div class="input-field">
                <i class="fas fa-user"></i>
                {{ form_widget(form.nom, {'attr': {'placeholder': 'Nom'}}) }}
            </div>
            {{ form_errors(form.nom) }}

            <!-- Prénom Field -->
            <div class="input-field">
                <i class="fas fa-user"></i>
                {{ form_widget(form.prenom, {'attr': {'placeholder': 'Prénom'}}) }}
            </div>
            {{ form_errors(form.prenom) }}

            <!-- Age Field -->
            <div class="input-field">
                <i class="fas fa-calendar-alt"></i>
                {{ form_widget(form.age, {'attr': {'placeholder': 'Age'}}) }}
            </div>
            {{ form_errors(form.age) }}

            <!-- Email Field -->
            <div class="input-field">
                <i class="fas fa-envelope"></i>
                {{ form_widget(form.mail, {'attr': {'placeholder': 'Email'}}) }}
            </div>
            {% for error in form.mail.vars.errors %}
                <div class="text-danger">{{ error.message }}</div>
            {% endfor %}

            <!-- Phone Field -->
            <div class="input-field">
                <i class="fas fa-phone"></i>
                {{ form_widget(form.phone, {'attr': {'placeholder': 'Numéro de téléphone'}}) }}
            </div>
            {{ form_errors(form.phone) }}

            <!-- Password Field -->
            <div class="input-field">
                <i class="fas fa-lock"></i>
                {{ form_widget(form.password, {'attr': {'placeholder': 'Password'}}) }}
            </div>
            {% for error in form.password.vars.errors %}
                <div class="text-danger">{{ error.message }}</div>
            {% endfor %}

            <div style="display: none;">
                {{ form_widget(form.role) }}
            </div>
            <input type="submit" class="btn" value="Sign up" />

            <p class="social-text">Or Sign up with social platforms</p>

            <div class="social-media">
                <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-google"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
            </div>
        {{ form_end(form) }}



        </div>
      </div>

      <div class="panels-container">
        <div class="panel left-panel">
          <div class="content">
            <h3>New here ?</h3>
            <p>
              Lorem ipsum, dolor sit amet consectetur adipisicing elit. Debitis,
              ex ratione. Aliquid!
            </p>
            <button class="btn transparent" id="sign-up-btn">
              Sign up
            </button>
          </div>
          <img src="{{asset('assetsFront/img/log.svg')}}" class="image" alt="" />
        </div>
        <div class="panel right-panel">
          <div class="content">
            <h3>One of us ?</h3>
            <p>
              Lorem ipsum dolor sit amet consectetur adipisicing elit. Nostrum
              laboriosam ad deleniti.
            </p>
            <button class="btn transparent" id="sign-in-btn">
              Sign in
            </button>
          </div>
          <img src="{{asset('assetsFront/img/register.svg')}}" class="image" alt="" />
        </div>
      </div>
    </div>

    <script src="{{asset('assetsFront/js/app.js')}}"></script>
  </body>
</html>
