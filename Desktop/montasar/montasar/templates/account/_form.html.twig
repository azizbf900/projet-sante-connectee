<div class="form-container">
    <div id="center-text">
       <h1>Formulaire De Création De Compte</h1>
    </div>
    <div id="backe">
        <a id="back" href="{{ path('app_account_index') }}"><button id="backlist">Back to list</button></a>
    </div>
    {{ form_start(form) }}
        <div id="form">
            <div class="form-group">
                {{ form_row(form.nom, {'attr': {'class': 'form-control', 'placeholder': "Nom"}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Prénom'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.age, {'attr': {'class': 'form-control', 'placeholder': 'Âge'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.mail, {'attr': {'class': 'form-control', 'placeholder': 'Email'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.phone, {'attr': {'class': 'form-control', 'placeholder': 'Numéro de téléphone','novalidate': 'novalidate'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.role, {'attr': {'class': 'form-control', 'placeholder': 'Rôle'}}) }}
            </div>
            <div class="form-group">
                {{ form_row(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Mot de Passe'}}) }}
            </div>

            <div id="submit">
                <button id="submitbutton" type="submit" class="btn btn-primary">{{ button_label|default('SUBMIT') }}</button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
